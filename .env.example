SCRAPECREATORS_API_KEY=your_scrapecreators_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# SUPABASE_ANON_KEY is the public/anon API key.  It is required: every
# user-facing request is served via a per-request RLS-scoped client built
# from this key plus the caller's JWT (audit H1).  Find it under
# Project Settings → API → `anon` key.
SUPABASE_ANON_KEY=your_supabase_anon_key_here
CORS_ALLOWED_ORIGINS=http://localhost:3000
PORT=3001
LOG_LEVEL=info

# Number of forwarded-proxy hops to trust (audit M4).  `1` is correct
# behind a single load balancer (Vercel, Render, Fly.io, AWS ALB).  Set
# to a CIDR list when fronted by multiple known proxies, or `false` to
# disable proxy trust entirely (e.g. local dev without a reverse proxy).
TRUST_PROXY=1

# Bulk-search rate limit & concurrency (audit M1).
# BULK_SEARCH_RATE_LIMIT defaults to 5 requests / 15 min / user.
# BULK_SEARCH_CONCURRENCY defaults to 3 concurrent outbound API calls and
# is hard-capped at 10 in src/controllers/influencers.controller.ts so a
# misconfigured value cannot exhaust the upstream paid-API quota or the
# global IP rate limit (audit L5).  Values >10 are silently clamped to 10.
# SCRAPER_CACHE_TTL_MS defaults to 600000 (10 min).
# BULK_SEARCH_RATE_LIMIT=5
# BULK_SEARCH_CONCURRENCY=3   # default; minimum 1, capped at 10
# SCRAPER_CACHE_TTL_MS=600000

# ---------------------------------------------------------------------------
# JWT Key Provider configuration
# ---------------------------------------------------------------------------
# KEY_PROVIDER selects how the JWT signing / verification key is obtained.
# Supported values: env | aws-kms | aws-secrets-manager | rs256-pem | jwks
# Default: env
#
# Production (NODE_ENV=production) refuses to boot with KEY_PROVIDER=env
# unless ALLOW_INSECURE_KEY_PROVIDER=true is set explicitly (audit M10):
# a leaked SUPABASE_JWT_SECRET would otherwise allow forging admin tokens.
KEY_PROVIDER=env
# ALLOW_INSECURE_KEY_PROVIDER=false

# --- Provider: env (default, development only) ---
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# --- Provider: aws-kms (envelope encryption) ---
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# KMS_ENCRYPTED_SECRET=<base64-encoded ciphertext>
# AWS_REGION=us-east-1

# --- Provider: aws-secrets-manager ---
# AWS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:my-jwt-secret
# AWS_SECRET_KEY=jwt_secret          # optional JSON key within the secret
# AWS_REGION=us-east-1

# --- Provider: rs256-pem (asymmetric RS256, static public key) ---
# Paste a PEM-encoded RSA public key.  Literal `\n` sequences are accepted
# so the key can be kept on a single line in secret stores.
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# --- Provider: jwks (asymmetric RS256 via JWKS endpoint, recommended) ---
# Point at the JWKS document published by your Supabase project once the
# project is migrated to asymmetric JWT signing.  Verification algorithms
# are pinned to RS256; `kid` rotation is handled automatically.
# JWT_JWKS_URI=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# ---------------------------------------------------------------------------
# Column-level PII field encryption (optional)
# ---------------------------------------------------------------------------
# When set, PII fields (full_name, bio, profile_pic_url, profile_url) are
# encrypted at rest using AES-256-GCM with envelope encryption via AWS KMS.
# Omit to disable field-level encryption (development / non-sensitive data).
# FIELD_ENCRYPTION_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# AWS_REGION=us-east-1
