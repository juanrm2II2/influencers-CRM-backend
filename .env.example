SCRAPECREATORS_API_KEY=your_scrapecreators_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
CORS_ALLOWED_ORIGINS=http://localhost:3000
PORT=3001
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# JWT Key Provider configuration
# ---------------------------------------------------------------------------
# KEY_PROVIDER selects how the JWT signing secret is obtained.
# Supported values: env | aws-kms | aws-secrets-manager
# Default: env
KEY_PROVIDER=env

# --- Provider: env (default, development only) ---
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# --- Provider: aws-kms (envelope encryption) ---
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# KMS_ENCRYPTED_SECRET=<base64-encoded ciphertext>
# AWS_REGION=us-east-1

# --- Provider: aws-secrets-manager ---
# AWS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:my-jwt-secret
# AWS_SECRET_KEY=jwt_secret          # optional JSON key within the secret
# AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Column-level PII field encryption (optional)
# ---------------------------------------------------------------------------
# When set, PII fields (full_name, bio, profile_pic_url, profile_url) are
# encrypted at rest using AES-256-GCM with envelope encryption via AWS KMS.
# Omit to disable field-level encryption (development / non-sensitive data).
# FIELD_ENCRYPTION_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# AWS_REGION=us-east-1
