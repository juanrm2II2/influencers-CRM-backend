# ---- Runtime ----
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# ---- CORS ----
# Comma-separated list of allowed origins for the API.
CORS_ORIGINS=http://localhost:3000

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ---- Supabase ----
# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=
# anon/public key — safe to expose but we still keep it server-side.
SUPABASE_ANON_KEY=
# Service-role key — NEVER expose to clients. Used for privileged server ops.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret used to verify access tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=

# ---- ScrapeCreators ----
SCRAPECREATORS_BASE_URL=https://api.scrapecreators.com
SCRAPECREATORS_API_KEY=
# Seconds to keep cached scrape responses before re-fetching.
SCRAPECREATORS_CACHE_TTL_SECONDS=86400

# ---- Audit log ----
# HMAC secret used to seed the audit log hash chain. Rotate via key versioning.
AUDIT_HMAC_SECRET=

# ---- KYC / PII encryption ----
# 32-byte key (hex-encoded, 64 chars) used for AES-256-GCM application-layer
# encryption of KYC fields. Rotate via envelope encryption.
KYC_ENCRYPTION_KEY=

# ---- Jobs ----
JOBS_ENABLED=true
JOBS_METRICS_REFRESH_CRON=0 3 * * *
JOBS_KYC_EXPIRY_CRON=0 4 * * *
JOBS_AUDIT_VERIFY_CRON=0 5 * * *

# ---- Observability (optional) ----
SENTRY_DSN=
